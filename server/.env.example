# OpenCreator server configuration
DATABASE_URL=postgresql://localhost:5432/openfirehouse
JWT_SECRET=change-me-to-a-long-random-string

# YouTube integration (Google Cloud Console -> APIs & Services -> Credentials)
# 1. Create an OAuth 2.0 Client ID (type: Web application)
# 2. Add authorized redirect URI: http://localhost:3012/api/youtube/callback
# 3. Enable "YouTube Data API v3" and "YouTube Analytics API" for the project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3012/api/youtube/callback
CLIENT_URL=http://localhost:5180
